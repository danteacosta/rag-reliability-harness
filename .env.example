# Optional — not required for CI or `make all` (offline hash embedder + in-memory store).

# Postgres / pgvector local demo (see docker-compose.yml)
# DATABASE_URL=postgresql://rag:rag@localhost:5432/rag_harness
# PGVECTOR_DSN=postgresql://rag:rag@localhost:5432/rag_harness

# Langfuse tracing (adapter no-ops when these are unset)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Closed-loop alert webhook (optional; file alert always written on gate fail)
# ALERT_WEBHOOK_URL=https://hooks.example.com/rag-reliability
